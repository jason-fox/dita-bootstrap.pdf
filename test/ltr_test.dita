<?xml version="1.0" encoding="UTF-8"?>
<!--
  LTR Layout Test Case
  Expected: 
  1. The grid-row should follow standard Left-to-Right.
  2. The paragraph in the first col should be on the LEFT.
  3. The card should occupy the full width of the column.
-->
<!DOCTYPE topic PUBLIC "-//Infotexture//DTD DITA Bootstrap Topic//EN" "bootstrap-topic.dtd">
<topic id="ltr_test">
  <title>LTR Grid and Card Test</title>
  <body>

    <p dir="ltr">Standard LTR text inside a grid column. This should be aligned to the left.</p>
    <bodydiv>
      <grid-row dir="ltr">
        <grid-col>
          <p>Standard LTR text inside a grid column. This should be aligned to the left.</p>
        </grid-col>
      </grid-row>
    </bodydiv>

    <bodydiv>
      <grid-row dir="ltr">
        <grid-col>
          <card>
            <title>LTR Card</title>
            <p>Card content should be left-aligned and the card itself should appear on the left side of the grid.</p>
          </card>
        </grid-col>
      </grid-row>
    </bodydiv>
  </body>
</topic>
